{
  "info": {
    "name": "Backend Tracking API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "health"
          ]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"secret\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"refresh_token\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/refresh",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "refresh"
          ]
        }
      }
    },
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"New User\",\n    \"email\": \"newuser@example.com\",\n    \"password\": \"password123\",\n    \"is_admin\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users"
          ]
        }
      }
    },
    {
      "name": "List Orders",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders?page=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "orders"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "Get Order",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "orders",
            "{{orderId}}"
          ]
        }
      }
    },
    {
      "name": "Order Available Transitions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/available-transitions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "orders",
            "{{orderId}}",
            "available-transitions"
          ]
        }
      }
    },
    {
      "name": "Update Order Status",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "status",
              "value": "empaquetado",
              "type": "text"
            },
            {
              "key": "delivery_image",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "orders",
            "{{orderId}}",
            "status"
          ]
        }
      }
    },
    {
      "name": "Order History",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/history",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "orders",
            "{{orderId}}",
            "history"
          ]
        }
      }
    },
    {
      "name": "Order Logs",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/logs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "orders",
            "{{orderId}}",
            "logs"
          ]
        }
      }
    },
    {
      "name": "Sync Orders",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"start_date\": \"2026-03-01\",\n    \"end_date\": \"2026-03-05\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/orders/sync",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "orders",
            "sync"
          ]
        }
      }
    },
    {
      "name": "WooCommerce Webhook",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"id\": 123,\n    \"status\": \"completed\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/webhooks/woocommerce",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "webhooks",
            "woocommerce"
          ]
        }
      }
    }
  ]
}